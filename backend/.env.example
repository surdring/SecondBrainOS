# Postgres
# 用途：事实源与派生索引存储（PostgreSQL + pgvector）
# 默认值：本地 Docker/本机 Postgres 示例连接串
# 获取方式：按你的部署环境填写；如使用 docker-compose，请使用对应 service 名作为 host
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/secondbrainos

# Redis
# 用途：缓存与队列（RQ）依赖的 Redis
# 默认值：本地 Redis 示例连接串
# 获取方式：按你的部署环境填写；如 Redis 需要密码，格式：redis://:password@host:port/db
REDIS_URL=redis://localhost:6379/5
# 用途：RQ 队列名称
# 默认值：sbo_default
RQ_QUEUE_NAME=sbo_default

# Neo4j
# 用途：图谱增强（阶段 2 / deep 模式可选能力）；MVP 可不启用
# 默认值：本地 Neo4j 示例连接信息
# 获取方式：按你的部署环境填写
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please_change_me
NEO4J_DATABASE=neo4j

# LLM / Provider / Embeddings
# 用途：后端/worker 调用大模型与 embeddings 的服务端密钥（禁止下发到前端）
# 获取方式：从对应服务商控制台获取 API Key；本地 llama.cpp/ollama 可不需要 key
LLM_LLAMA_BASE_URL=http://localhost:11434
LLM_LLAMA_API_KEY=
LLM_LLAMA_MODEL_ID=

PROVIDER_BASE_URL=
PROVIDER_API_KEY=
PROVIDER_MODEL_ID=

SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_EMBEDDING_MODEL=

# WeKnora
# 用途：Episodic Memory 外部引擎（HTTP REST）；fast 模式不依赖，deep 模式/episodic/feedback 等链路需要
# 默认值：WEKNORA_ENABLE=false（不启用）
# 获取方式：部署 WeKnora 后填写其 Base URL 与 API Key；Base URL 可包含或不包含 /api/v1
WEKNORA_ENABLE=false
WEKNORA_BASE_URL=http://localhost:8080/api/v1
WEKNORA_API_KEY=
# 用途：WeKnora HTTP 请求超时（毫秒）
# 默认值：10000
WEKNORA_REQUEST_TIMEOUT_MS=10000
# 用途：WeKnora 检索 top_k
# 默认值：8
WEKNORA_RETRIEVAL_TOP_K=8
# 用途：SBO 侧二次过滤阈值（0..1，留空表示不启用）
WEKNORA_RETRIEVAL_THRESHOLD=
# 用途：时间衰减率（>0）
# 默认值：0.1
WEKNORA_TIME_DECAY_RATE=0.1
# 用途：语义分数与时间分数权重（0..1 且两者之和必须等于 1）
# 默认值：0.7 + 0.3
WEKNORA_SEMANTIC_WEIGHT=0.7
WEKNORA_TIME_WEIGHT=0.3
# 用途：WeKnora 不可用时的降级策略（fail/degrade）
# fail：返回结构化错误（默认）
# degrade：降级为 fast 模式并标记降级信息
WEKNORA_DEGRADATION_STRATEGY=fail
